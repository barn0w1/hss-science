# ============================================================
# hss-science Environment Variables
# ============================================================
# このファイルはアプリケーションが要求する環境変数の一覧です。
# 実際の運用では .env ファイルにコピーするか、コンテナの
# 環境変数として設定してください。
#
# [required] = 起動時に未設定だとプロセスが即時終了する必須変数
# [optional] = デフォルト値があり、省略可能な変数
# ============================================================

# -----------------------------------------------------------
# 共通設定 (Accounts gRPC / Accounts BFF 両方で使用)
# -----------------------------------------------------------

# [optional] 実行環境。"production" で JSON ログ、"development" で Text ログ。
# デフォルト: production
ENV=development

# [optional] ログレベル。DEBUG, INFO, WARN, ERROR のいずれか。
# デフォルト: INFO
LOG_LEVEL=DEBUG

# -----------------------------------------------------------
# Accounts gRPC Service (server/services/accounts)
# -----------------------------------------------------------

# [optional] gRPC サーバーの待受ポート。
# デフォルト: 50051
# PORT=50051

# [required] PostgreSQL 接続 URL。
DATABASE_URL=postgres://user:password@localhost:5432/hss_accounts?sslmode=disable

# [required] Discord OAuth2 アプリケーションのクライアント ID。
# https://discord.com/developers/applications から取得。
DISCORD_CLIENT_ID=your-discord-client-id

# [required] Discord OAuth2 アプリケーションのクライアントシークレット。
DISCORD_CLIENT_SECRET=your-discord-client-secret

# [required] Discord OAuth2 のコールバック URL。
# BFF の /api/v1/oauth/callback エンドポイントを指定する。
DISCORD_REDIRECT_URL=https://accounts.hss-science.org/api/v1/oauth/callback

# -----------------------------------------------------------
# Accounts BFF (server/bff/accounts)
# -----------------------------------------------------------

# [optional] BFF HTTP サーバーの待受ポート。
# デフォルト: 8080
# PORT=8080

# [optional] Accounts gRPC サービスのアドレス。
# デフォルト: localhost:50051
ACCOUNTS_GRPC_ADDR=localhost:50051

# [optional] 使用する OAuth プロバイダ名。
# デフォルト: discord
OAUTH_PROVIDER=discord

# [required] セッション Cookie の HMAC 署名用キー (32バイト)。
# 生成例: openssl rand -base64 32
SESSION_HASH_KEY=your-32-byte-hash-key-here======

# [required] セッション Cookie の AES 暗号化用キー (16バイト)。
# 生成例: openssl rand -base64 16
SESSION_BLOCK_KEY=your-16byte-key=

# [optional] セッション Cookie の Secure フラグ。
# 本番では省略 (true)。ローカル HTTP 開発時のみ "false" に設定。
# デフォルト: true (SESSION_SECURE != "false" なら Secure)
SESSION_SECURE=true

# [optional] 許可するオーディエンスとリダイレクト URI のマッピング。
# フォーマット: audience1=https://prefix1,https://prefix2;audience2=https://prefix3
# 例: drive アプリからの SSO コールバックを許可する場合:
ALLOWED_AUDIENCES=drive=https://drive.hss-science.org/auth/callback
