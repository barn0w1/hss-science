# Accounts Service Configuration
ENV=development
PORT=50051
LOG_LEVEL=info

# PostgreSQL connection string
DATABASE_URL=postgres://accounts:password@localhost:5432/accounts?sslmode=disable

# Ed25519 private key for JWT signing (PEM file path)
JWT_PRIVATE_KEY_PATH=./dev_ed25519_private.pem

# JWT configuration
JWT_ISSUER=hss-science.org
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
