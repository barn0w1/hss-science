# =============================================================================
# accounts-idp — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables marked as [required] must be set before the service will start.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the HTTP server listens on.
PORT=8080

# Full URL of this OIDC Provider, used as the `iss` (issuer) claim in all
# tokens and as the base for the discovery document URL.
# Must match the URL clients use to reach this service.
# [required]
ISSUER=http://localhost:8080

# Set to true to allow an HTTP (non-HTTPS) issuer URL. Required for local
# development when not running behind a TLS-terminating proxy.
DEV_MODE=true

# Minimum log level. One of: debug, info, warn, error.
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string. The schema must already be applied via
# migrations/001_initial_schema.sql before starting the service.
# [required]
DATABASE_URL=postgres://postgres:password@localhost:5432/accounts?sslmode=disable

# -----------------------------------------------------------------------------
# Database connection pool
# -----------------------------------------------------------------------------

# Maximum number of open connections to the database.
DB_MAX_OPEN_CONNS=25

# Maximum number of idle connections in the pool.
DB_MAX_IDLE_CONNS=5

# Maximum amount of time a connection may be reused (Go duration string).
DB_CONN_MAX_LIFETIME=5m

# -----------------------------------------------------------------------------
# Cryptography
# -----------------------------------------------------------------------------

# 32-byte AES key used by zitadel/oidc to encrypt authorization codes and
# other internal state. Must be exactly 32 bytes, base64-encoded (standard
# encoding with padding).
#
# Generate a secure random key with:
#   openssl rand -base64 32
#
# !! DO NOT use the placeholder below in any non-local environment !!
# [required]
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# -----------------------------------------------------------------------------
# Google OIDC (upstream authentication provider)
# -----------------------------------------------------------------------------

# OAuth2 client credentials from Google Cloud Console.
# Create a credential of type "OAuth 2.0 Client ID" > "Web application" at:
#   https://console.cloud.google.com/apis/credentials
# [required]
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# [required]
GOOGLE_CLIENT_SECRET=your-client-secret

# The callback URL that Google will redirect to after authentication.
# Must be added to the "Authorised redirect URIs" list in Google Cloud Console.
# Should be: <ISSUER>/login/callback
# [required]
GOOGLE_REDIRECT_URI=http://localhost:8080/login/callback

# -----------------------------------------------------------------------------
# Token lifetimes
# -----------------------------------------------------------------------------

# Lifetime of issued access tokens (Go duration string).
ACCESS_TOKEN_LIFETIME=5m

# Lifetime of issued refresh tokens (Go duration string).
REFRESH_TOKEN_LIFETIME=5h

# Lifetime of issued ID tokens (Go duration string).
ID_TOKEN_LIFETIME=1h
