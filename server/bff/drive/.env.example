# Drive BFF Configuration
ENV=development
PORT=8080
LOG_LEVEL=info

# Google OIDC
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback

# Cookie encryption keys (32 bytes each, base64-encoded)
# Generate with: head -c 32 /dev/urandom | base64
COOKIE_HASH_KEY=base64-encoded-32-bytes-for-hmac
COOKIE_BLOCK_KEY=base64-encoded-32-bytes-for-aes

# Cookie domain (empty string for localhost in development)
COOKIE_DOMAIN=

# Where to redirect after successful login
POST_LOGIN_REDIRECT=http://localhost:5173/

# gRPC backend
ACCOUNTS_GRPC_ADDR=localhost:50051
