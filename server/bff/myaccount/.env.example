# =============================================================================
# myaccount-bff — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables marked as [required] must be set before the service will start.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the HTTP server listens on.
PORT=8081

# Minimum log level. One of: debug, info, warn, error.
LOG_LEVEL=info

# Set to true to use the plain cookie name "myaccount_session" instead of
# "__Host-myaccount_session". The __Host- prefix requires HTTPS and is
# enforced in production. Set to true only for local HTTP development.
DEV_MODE=true

# -----------------------------------------------------------------------------
# OIDC Relying Party
# -----------------------------------------------------------------------------

# Base URL of the accounts-idp OpenID Provider. The BFF performs OIDC
# discovery by fetching <OIDC_ISSUER>/.well-known/openid-configuration on
# startup. Must exactly match accounts-idp's ISSUER value.
# [required]
OIDC_ISSUER=http://localhost:8080

# Client ID registered in accounts-idp's clients table.
# [required]
OIDC_CLIENT_ID=myaccount-bff

# Client secret (plaintext). Must match the bcrypt hash stored in the
# accounts-idp clients table for this client ID.
#
# Generate a secret with:
#   openssl rand -hex 32
#
# Hash it for the DB with:
#   htpasswd -bnBC 12 "" <secret> | tr -d ':\n'
#
# !! DO NOT use the placeholder below in any non-local environment !!
# [required]
OIDC_CLIENT_SECRET=replace-me-with-a-real-secret

# The OAuth2 redirect URI. Must exactly match one of the redirect_uris
# registered for this client in accounts-idp.
# [required]
OIDC_REDIRECT_URI=http://localhost:8081/auth/callback

# -----------------------------------------------------------------------------
# Session store (Redis)
# -----------------------------------------------------------------------------

# Redis connection URL. Supports redis://, rediss:// (TLS), and
# redis+sentinel:// schemes.
# [required]
REDIS_URL=redis://localhost:6379/0

# 32-byte key used to generate cryptographically random session IDs.
# Must be exactly 32 bytes, base64-encoded (standard encoding with padding).
#
# Generate a secure random key with:
#   openssl rand -base64 32
#
# !! DO NOT use the placeholder below in any non-local environment !!
# [required]
SESSION_SECRET=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Session lifetime (also used as Redis key TTL and cookie Max-Age).
# Go duration string: e.g. 24h, 168h (7 days), 30m.
SESSION_MAX_AGE=24h

# -----------------------------------------------------------------------------
# accounts-idp gRPC backend
# -----------------------------------------------------------------------------

# Host and port of the accounts-idp gRPC Resource Server.
# In production this should be an internal DNS name or service address.
# [required]
ACCOUNTS_GRPC_ADDR=localhost:9090

# -----------------------------------------------------------------------------
# SPA / CORS
# -----------------------------------------------------------------------------

# Origin of the myaccount-spa. Used as the sole allowed CORS origin.
# AllowCredentials is always true, so only one origin can be specified.
#
# In development this is the Vite dev server. In production, the SPA
# is served by nginx at the same host as the BFF, so this should be
# set to the production SPA origin (e.g. https://myaccount.example.com).
# [required]
SPA_ORIGIN=http://localhost:5174
